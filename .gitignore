# dependencies
node_modules/
.expo/
.expo-shared/

# native builds
android/
ios/
*.apk
*.ipa
build/
dist/

# models (too large to commit — fetched per data/README)
*.gguf
models/

# datasets — raw dumps AND the generated DB (~18MB). Regenerate with: npm run data
data/raw/
data/pharos.db
# the DB staged as an RN asset for on-device builds (regenerate: npm run data && cp data/pharos.db app/assets/)
app/assets/pharos.db

# compiled core for the RN app (generated by `npm run build:core` / prepare)
core/dist/

# QVAC mobile worker bundle, regenerated by `expo prebuild` (like android/)
app/qvac/

# local env & secrets
.env
.env.*

# logs & captures from local runs (keep curated evidence elsewhere)
*.log
*.pcap

# OS
.DS_Store
Thumbs.db
